{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!**/potentiel-keycloak",
      "!packages/applications/notifications/src/templates/layouts/email.layout.html"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    /* 
      Merci de laisser les règles linter "domains" AVANT les rules custom 
      sinon y a un problème de surchage
    */
    "domains": {
      "next": "recommended",
      "react": "recommended",
      "project": "recommended"
    },
    "rules": {
      "recommended": true,
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [{ "group": "**/dist/**" }, { "group": "**/src/**" }]
          }
        },
        "noNonNullAssertion": "error"
      },
      "correctness": {
        "noUnusedImports": {
          "fix": "safe",
          "level": "error"
        }
      },
      "complexity": {
        "useLiteralKeys": "off"
      },
      "nursery": {
        "noFloatingPromises": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn"
      }
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single" }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",

          "options": {
            "groups": [
              // Node standard packages
              ":NODE:",
              ":BLANK_LINE:",

              // Packages, except Potentiel ones
              [":PACKAGE:", "!@potentiel-*/**"],
              ":BLANK_LINE:",

              // Potentiel packages
              "@potentiel-*/**",
              ":BLANK_LINE:",

              // Other imports, starting with @/ imports
              ":ALIAS:",
              "**"
            ]
          }
        }
      }
    }
  },
  "css": {
    "linter": {
      "enabled": false
    }
  }
}
