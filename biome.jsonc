{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!**/legacy", "!**/.next", "!**/potentiel-keycloak"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "style": {
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [{ "group": "**/dist/**" }, { "group": "**/src/**" }]
          }
        }
      },
      "correctness": {
        "noUnusedImports": {
          "fix": "safe",
          "level": "error",
          "options": {}
        }
      }
    },
    "domains": {
      "next": "recommended",
      "react": "recommended",
      "project": "recommended"
    }
  },
  "javascript": {
    "formatter": { "quoteStyle": "single" }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",

          "options": {
            "groups": [
              // Node standard packages
              ":NODE:",
              ":BLANK_LINE:",

              // Packages, except Potentiel ones
              [":PACKAGE:", "!@potentiel-*/**"],
              ":BLANK_LINE:",

              // Potentiel packages
              "@potentiel-*/**",
              ":BLANK_LINE:",

              // Other imports, starting with @/ imports
              ":ALIAS:",
              "**"
            ]
          }
        }
      }
    }
  }
}
