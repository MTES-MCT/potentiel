{
  "name": "@potentiel-applications/ssr",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run prebuild && tsx watch -r dotenv/config src/server.ts",
    "dev:debug": "node --inspect -r dotenv/config -r tsx/cjs src/server.ts",
    "start": "NODE_ENV=production node -r dotenv/config dist/server.js",
    "build": "npm run prebuild && npm run build:server && next build",
    "build:server": "tsc -p tsconfig.server.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prebuild": "react-dsfr update-icons --silent",
    "test": "tsx -r dotenv/config --test src/**/*.test.ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo .next",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@potentiel-applications/api": "*",
    "@potentiel-applications/api-documentation": "*",
    "@potentiel-applications/bootstrap": "*",
    "@potentiel-applications/document-builder": "*",
    "@potentiel-applications/notifications": "*",
    "@potentiel-applications/request-context": "*",
    "@potentiel-applications/routes": "*",
    "@potentiel-domain/appel-offre": "*",
    "@potentiel-domain/entity": "*",
    "@potentiel-domain/projet": "*",
    "@potentiel-domain/reseau": "*",
    "@potentiel-domain/statistiques-utilisation": "*",
    "@potentiel-domain/utilisateur": "*",
    "@potentiel-infrastructure/dn-api-client": "*",
    "@potentiel-infrastructure/filigrane-facile-client": "*",
    "@potentiel-infrastructure/geo-api-client": "*",
    "@potentiel-libraries/csv": "*",
    "@potentiel-libraries/iso8601-datetime": "*",
    "@potentiel-libraries/monads": "*",
    "@potentiel-libraries/monitoring": "*",
    "@potentiel-libraries/pdf": "*",
    "@codegouvfr/react-dsfr": "1.32.4",
    "@emotion/react": "11.14.0",
    "@emotion/server": "11.11.0",
    "@emotion/styled": "11.14.0",
    "@iframe-resizer/react": "5.4.4",
    "@mui/lab": "7.0.1-beta.22",
    "@mui/material": "7.3.8",
    "@scalar/nextjs-api-reference": "0.10.14",
    "@sentry/core": "10.65.0",
    "@sentry/nextjs": "10.65.0",
    "better-auth": "1.6.23",
    "clsx": "2.1.1",
    "crisp-sdk-web": "1.0.25",
    "flat": "6.0.1",
    "mediateur": "0.3.0",
    "next": "16.2.10",
    "pg": "8.16.3",
    "rate-limiter-flexible": "6.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "0.35.3",
    "zod": "4.1.9"
  },
  "devDependencies": {
    "@types/pg": "8.15.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.4.21",
    "diff": "8.0.4",
    "postcss": "8.5.15",
    "sass": "1.86.3",
    "tailwindcss": "3.4.17"
  }
}
