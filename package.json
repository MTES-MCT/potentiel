{
  "name": "potentiel-monorepo",
  "description": "Monorepo du projet potentiel",
  "workspaces": [
    "./packages/config/*",
    "./packages/libraries/*",
    "./packages/domain/*",
    "./packages/infrastructure/*",
    "./packages/statistiques/*",
    "./packages/applications/*",
    "./packages/specifications"
  ],
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start": "npx --offline foreman start --procfile Procfile --port 3000",
    "start:web": "npm run start -w @potentiel-applications/ssr",
    "start:subscribers": "npm run start -w @potentiel-applications/subscribers",
    "up": "./.scripts/docker-up.sh",
    "down": "./.scripts/docker-down.sh",
    "up:test": "./.scripts/docker-up-test.sh",
    "down:test": "./.scripts/docker-down-test.sh",
    "build": "turbo run build",
    "build:dev": "turbo run build --filter=@potentiel-applications/subscribers --filter=@potentiel-applications/ssr^...",
    "build:cli": "turbo run build --filter=@potentiel/cli...",
    "build:test": "turbo run build --filter=@potentiel-applications/ssr^... --filter=@potentiel-applications/subscribers",
    "clean": "turbo run clean && rm -rf .turbo",
    "predev": "npm run up && npm run build:dev",
    "dev": "npm run predev && npx --offline foreman start --procfile Procfile.dev --port 3000",
    "dev:web": "npm run dev -w @potentiel-applications/ssr",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "storybook:documents": "npm run storybook -w @potentiel-applications/document-builder",
    "db:restart": "docker stop potentiel_db && docker rm potentiel_db && npm run up",
    "pretest": "npm run down:test && npm run up:test && npm run build:test",
    "test:libraries": "npm run pretest && turbo run test --filter=@potentiel-domain/* --filter=@potentiel-libraries/* --filter=@potentiel-infrastructure/*",
    "test:apps": "npm run pretest && turbo run test --filter=@potentiel-applications/*",
    "prespecs": "npm run down:test && npm run up:test && turbo run build --filter=@potentiel/specifications...",
    "specs": "npm run prespecs && npm run test -w @potentiel/specifications -- ",
    "specs:select": "npm run prespecs && npm run test:select -w @potentiel/specifications",
    "update:dump": "./.database/scripts/update-potentiel-dump.sh",
    "update:dump-metabase": "./.database/scripts/update-metabase-dump.sh",
    "update:ts-references": "update-ts-references"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MTES-MCT/potentiel.git"
  },
  "author": "L'équipe Potentiel <team@potentiel.beta.gouv.fr> (https://potentiel.beta.gouv.fr/)",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/MTES-MCT/potentiel/issues"
  },
  "homepage": "https://github.com/MTES-MCT/potentiel#readme",
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@faker-js/faker": "10.4.0",
    "chai": "6.2.2",
    "foreman": "3.0.1",
    "gitmoji-cli": "9.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "tsx": "4.22.4",
    "turbo": "2.9.18",
    "typescript": "6.0.3",
    "update-ts-references": "6.0.0",
    "wait-for-expect": "4.0.0"
  },
  "engines": {
    "node": "^24.14.0"
  },
  "dependencies": {
    "ts-pattern": "5.9.0"
  },
  "packageManager": "npm@11.17.0",
  "gitmoji": {
    "autoAdd": false,
    "emojiFormat": "emoji",
    "scopePrompt": false,
    "messagePrompt": false,
    "capitalizeTitle": true,
    "gitmojisUrl": "https://gitmoji.dev/api/gitmojis"
  }
}
